# ── Server ────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── MongoDB Atlas ─────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/nurixsoft?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-64-char-random-hex
JWT_REFRESH_SECRET=change-me-different-64-char-random-hex
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=365d

# ── Google OAuth ──────────────────────────────────────────
GOOGLE_WEB_CLIENT_ID=10728362727-ffgs5dt0na8jbij8u6089paa3uhakj5u.apps.googleusercontent.com

# ── Cloudinary ────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Firebase Admin (FCM) ──────────────────────────────────
# Path to service-account JSON (never commit the file)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ── SMTP (Nodemailer) ─────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=supportsujoydev@gmail.com
SMTP_PASS=app-password-here
MAIL_FROM="NurixSoft <supportsujoydev@gmail.com>"

# ── Admin bootstrap (first-run seed) ──────────────────────
ADMIN_EMAIL=supportsujoydev@gmail.com
ADMIN_PASSWORD=ChangeMeStrong!123
